{
  "name": "test-typescript-deploys",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "openapi-typescript ./openapi.yaml -o ./src/generated/api.ts",
    "deploy": "node --experimental-wasm-modules --no-warnings --import tsx ./src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openapi-fetch": "^0.13.0",
    "tower-package-wasm": "^0.3.59"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
